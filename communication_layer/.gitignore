```gitignore
# ==============================
# Python
# ==============================

__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/


# ==============================
# ROS2
# ==============================

install/
build/
log/

*.pyc


# ==============================
# IDE
# ==============================

.vscode/
.idea/


# ==============================
# OS
# ==============================

.DS_Store
Thumbs.db


# ==============================
# Machine learning
# ==============================

# Ignore trained weights
# Uncomment if model should not be uploaded
# models/*.pt


# ==============================
# ZED
# ==============================

*.svo
*.svo2


# ==============================
# Temporary files
# ==============================

*.tmp
*.bak
*.swp
```
