```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# VS Code
.vscode/

# PyCharm
.idea/

# Build
build/
dist/
*.egg-info/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Model weights (optional)
# Uncomment if you don't want to upload trained weights
# models/*.pt

# ZED recordings
*.svo

# Temporary files
*.tmp
*.bak
```
